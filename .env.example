# ===========================================
# FIREBASE CONFIG — Copie do Console Firebase
# ===========================================
# 1. Acesse https://console.firebase.google.com
# 2. Crie um projeto (ou use um existente)
# 3. Vá em Configurações > Geral > Seus apps > Web
# 4. Copie os valores abaixo
# 5. Renomeie este arquivo para .env

VITE_FIREBASE_API_KEY=sua-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Senha simples para acessar o painel admin (/admin)
VITE_ADMIN_PASSWORD=juspauta2026

